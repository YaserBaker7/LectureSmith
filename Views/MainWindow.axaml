<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LectureSmith.ViewModels"
        xmlns:m="using:LectureSmith.Models"
        x:Class="LectureSmith.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="LectureSmith"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f1a"
        Icon="avares://LectureSmith/Assets/app-icon.ico">

  <Window.Styles>
    <!-- Global styles -->
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#e0e0e0"/>
    </Style>
    <Style Selector="TextBox">
      <Setter Property="Background" Value="#1a1a2e"/>
      <Setter Property="Foreground" Value="#e0e0e0"/>
      <Setter Property="BorderBrush" Value="#2d3a5a"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="8,6"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="Background" Value="#1a1a2e"/>
      <Setter Property="Foreground" Value="#e0e0e0"/>
      <Setter Property="BorderBrush" Value="#2d3a5a"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
    </Style>

    <!-- Primary button -->
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#7c3aed"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="20,12"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#6d28d9"/>
    </Style>
    <Style Selector="Button.primary:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#3b3b52"/>
      <Setter Property="Foreground" Value="#666"/>
    </Style>

    <!-- Danger button -->
    <Style Selector="Button.danger">
      <Setter Property="Background" Value="#dc2626"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <!-- Small button -->
    <Style Selector="Button.small">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#999"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="Button.small:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2d3a5a"/>
    </Style>

    <!-- Settings button -->
    <Style Selector="Button.settings">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#a78bfa"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="FontSize" Value="18"/>
    </Style>
    <Style Selector="Button.settings:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1a1a2e"/>
    </Style>

    <!-- Secondary button -->
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#222543"/>
      <Setter Property="Foreground" Value="#a78bfa"/>
      <Setter Property="BorderBrush" Value="#2d3a5a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="FontWeight" Value="Normal"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2d3a5a"/>
      <Setter Property="BorderBrush" Value="#7c3aed"/>
      <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.secondary:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="#12122a"/>
      <Setter Property="Foreground" Value="#444"/>
      <Setter Property="BorderBrush" Value="#1a1a2e"/>
    </Style>

    <!-- Make text inside all buttons inherit button foreground -->
    <Style Selector="Button TextBlock">
      <Setter Property="Foreground" Value="{Binding $parent[Button].Foreground}"/>
    </Style>

    <!-- Drop zone -->
    <Style Selector="Border.dropzone">
      <Setter Property="BorderBrush" Value="#2d3a5a"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Background" Value="#12122a"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="MinHeight" Value="60"/>
    </Style>
    <Style Selector="Border.dropzone:pointerover">
      <Setter Property="BorderBrush" Value="#7c3aed"/>
      <Setter Property="Background" Value="#1a1040"/>
    </Style>

    <!-- Card -->
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#16163a"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="16"/>
      <Setter Property="Margin" Value="0,5"/>
      <Setter Property="BorderBrush" Value="#2d3a5a"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- Section header -->
    <Style Selector="TextBlock.sectionHeader">
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#a78bfa"/>
      <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <!-- File chip -->
    <Style Selector="Border.fileChip">
      <Setter Property="Background" Value="#1e2d4a"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,6"/>
      <Setter Property="Margin" Value="0,3"/>
    </Style>

    <!-- Accent bar -->
    <Style Selector="Border.accentBar">
      <Setter Property="Height" Value="3"/>
      <Setter Property="CornerRadius" Value="0,0,4,4"/>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">

    <!-- Top accent gradient bar -->
    <Border Grid.Row="0" Classes="accentBar">
      <Border.Background>
        <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
          <GradientStop Color="#7c3aed" Offset="0"/>
          <GradientStop Color="#a78bfa" Offset="0.5"/>
          <GradientStop Color="#4f46e5" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
    </Border>

    <!-- Main content area -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="16,12,16,12">

      <!-- ═══════ LEFT COLUMN ═══════ -->
      <ScrollViewer Grid.Column="0" Margin="0,0,8,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0">

          <!-- Header -->
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="🎓" FontSize="26"/>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="LectureSmith" FontSize="20" FontWeight="Bold" Foreground="#a78bfa"/>
                <TextBlock Text="AI-Powered Lecture Notes" FontSize="10" Foreground="#666"/>
              </StackPanel>
            </StackPanel>
            <Button Classes="settings" Grid.Column="1" Command="{Binding ToggleSettingsCommand}" Content="⚙" ToolTip.Tip="Settings"/>
          </Grid>

          <!-- Settings panel (collapsible) -->
          <Border Classes="card" IsVisible="{Binding ShowSettings}">
            <StackPanel Spacing="6">
              <TextBlock Classes="sectionHeader" Text="⚙ API Settings"/>
              <TextBlock Text="Gemini API Key:" FontSize="12" Foreground="#999"/>
              <Grid ColumnDefinitions="*,Auto">
                <TextBox Text="{Binding ApiKey}" PasswordChar="•" Watermark="Enter your Gemini API key..."/>
                <Button Grid.Column="1" Margin="6,0,0,0" Command="{Binding SaveApiKeyCommand}" Content="Save" Classes="secondary" Padding="14,8" HorizontalAlignment="Right"/>
              </Grid>
              <TextBlock Text="{Binding ApiKeyStatus}" FontSize="11" Foreground="#999"/>
              <TextBlock Text="Get a free key: aistudio.google.com" FontSize="10" Foreground="#555"/>
            </StackPanel>
          </Border>

          <!-- Configuration Card -->
          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Classes="sectionHeader" Text="📋 Configuration"/>

              <!-- Course -->
              <TextBlock Text="Course:" FontSize="12" Foreground="#999"/>
              <ComboBox ItemsSource="{Binding Courses}"
                        SelectedItem="{Binding SelectedCourse}"
                        IsEditable="True"
                        Text="{Binding SelectedCourse}"
                        PlaceholderText="e.g., Software Engineering or Physics"/>
              <TextBlock Text="Type your course name. It will be saved to this dropdown for future use."
                         FontSize="10" Foreground="#666" Margin="2,2,0,4" TextWrapping="Wrap"/>

              <!-- Mode -->
              <TextBlock Text="Mode:" FontSize="12" Foreground="#999"/>
              <ComboBox ItemsSource="{Binding LectureModes}"
                        SelectedItem="{Binding SelectedMode}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="m:LectureMode">
                    <TextBlock Text="{Binding Converter={x:Static vm:MainWindowViewModel.LectureModeDisplayConverter}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- Language -->
              <TextBlock Text="Language:" FontSize="12" Foreground="#999"/>
              <ComboBox ItemsSource="{Binding Languages}"
                        SelectedItem="{Binding SelectedLanguage}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="m:NoteLanguage">
                    <TextBlock Text="{Binding Converter={x:Static vm:MainWindowViewModel.LanguageDisplayConverter}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- Output Format -->
              <TextBlock Text="Output Format:" FontSize="12" Foreground="#999"/>
              <ComboBox ItemsSource="{Binding OutputFormats}"
                        SelectedItem="{Binding SelectedFormat}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="m:OutputFormat">
                    <TextBlock Text="{Binding Converter={x:Static vm:MainWindowViewModel.OutputFormatDisplayConverter}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- Clean Up Temporary Cache -->
              <Button Classes="secondary"
                      Command="{Binding CleanupCacheCommand}"
                      Margin="0,8,0,0">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="🧹" />
                  <TextBlock Text="Clean Up App Cache" />
                </StackPanel>
              </Button>
              <TextBlock Text="{Binding CleanupStatus}" 
                         Foreground="#00d084" 
                         FontSize="11" 
                         IsVisible="{Binding CleanupStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

              <!-- AI Model -->
              <TextBlock Text="AI Model:" FontSize="12" Foreground="#999"/>
              <ComboBox ItemsSource="{Binding AvailableModels}"
                        SelectedItem="{Binding SelectedModel}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="m:GeminiModelInfo">
                    <TextBlock Text="{Binding Converter={x:Static vm:MainWindowViewModel.ModelDisplayConverter}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Text="🟢 Free models  •  🔴 Paid models (billing is handled by Google AI Studio, not LectureSmith)"
                         FontSize="10" Foreground="#666" Margin="2,2,0,4" TextWrapping="Wrap"/>

              <!-- Slide Processing -->
              <TextBlock Text="Slide Processing:" FontSize="12" Foreground="#999"/>
              <ComboBox ItemsSource="{Binding SlideProcessingModes}"
                        SelectedItem="{Binding SelectedSlideProcessing}"
                        ToolTip.Tip="Text Only: fast, text extraction only&#x0a;OCR Enhanced: runs OCR to catch code screenshots&#x0a;Vision AI: sends slide images to AI (more tokens)">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="m:SlideProcessingMode">
                    <TextBlock Text="{Binding Converter={x:Static vm:MainWindowViewModel.SlideProcessingDisplayConverter}}"/>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <!-- Enable Thinking Toggle -->
              <CheckBox IsChecked="{Binding EnableThinking}" 
                        Margin="0,4,0,0">
                <StackPanel>
                  <TextBlock Text="Enable AI Thinking (Reasoning)" Foreground="#e0e0e0" FontSize="13"/>
                  <TextBlock Text="Uses tokens for reasoning — disable for longer outputs." Foreground="#999" FontSize="11"/>
                </StackPanel>
              </CheckBox>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- ═══════ RIGHT COLUMN ═══════ -->
      <ScrollViewer Grid.Column="1" Margin="8,0,0,0" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0">

          <!-- Materials Card -->
          <Border Classes="card">
            <StackPanel Spacing="8">
              <TextBlock Classes="sectionHeader" Text="📎 Materials"/>

              <!-- Slides drop zone -->
              <TextBlock Text="Lecture Slides (required)" FontSize="12" Foreground="#999"/>
              <Border Classes="dropzone" Name="SlidesDropZone"
                      DragDrop.AllowDrop="True"
                      IsVisible="{Binding SlidesFile, Converter={x:Static ObjectConverters.IsNull}}"
                      Tapped="SlidesDropZone_Tapped">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="📄 Drag &amp; drop slides PDF here" HorizontalAlignment="Center" Foreground="#777"/>
                  <TextBlock Text="or click to browse" HorizontalAlignment="Center" FontSize="11" Foreground="#555"/>
                </StackPanel>
              </Border>

              <!-- Slides file chip -->
              <Border Classes="fileChip" IsVisible="{Binding SlidesFile, Converter={x:Static ObjectConverters.IsNotNull}}">
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <TextBlock Text="📑" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="1" Text="{Binding SlidesFile.FileName}" VerticalAlignment="Center" Margin="8,0"/>
                  <Button Grid.Column="2" Classes="small" Command="{Binding RemoveSlidesCommand}" Content="✕"/>
                </Grid>
              </Border>

              <!-- Books drop zone -->
              <TextBlock Text="Reference Books (optional)" FontSize="12" Foreground="#999" Margin="0,6,0,0"/>
              <Border Classes="dropzone" Name="BooksDropZone"
                      DragDrop.AllowDrop="True"
                      Tapped="BooksDropZone_Tapped">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                  <TextBlock Text="📚 Drag &amp; drop book PDFs here" HorizontalAlignment="Center" Foreground="#777"/>
                  <TextBlock Text="or click to browse" HorizontalAlignment="Center" FontSize="11" Foreground="#555"/>
                </StackPanel>
              </Border>

              <!-- Book files list -->
              <ItemsControl ItemsSource="{Binding BookFiles}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="m:UploadedFile">
                    <Border Classes="fileChip">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="6">
                        <TextBlock Text="📕" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" Width="160" Text="{Binding ChapterInfo}" Watermark="e.g., Ch 10, p305-340" FontSize="11"/>
                        <Button Grid.Column="3" Classes="small"
                                Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).RemoveBookCommand}"
                                CommandParameter="{Binding}"
                                Content="✕"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Extra Notes Card -->
          <Border Classes="card">
            <StackPanel Spacing="4">
              <TextBlock Classes="sectionHeader" Text="📝 Extra Notes for AI"/>
              <TextBox Text="{Binding ExtraNotes}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       MinHeight="50"
                       MaxHeight="100"
                       Watermark="Optional: 'Focus on diagrams' or 'Include exam tips'"/>
            </StackPanel>
          </Border>

          <!-- Output Path -->
          <Border Classes="card">
            <StackPanel Spacing="4">
              <TextBlock Classes="sectionHeader" Text="💾 Save Location"/>
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                <TextBox Text="{Binding OutputPath}" Watermark="Select output folder..."/>
                <Button Grid.Column="1" Content="Browse" Classes="secondary" Padding="14,8"
                        Name="BrowseOutputButton" Click="BrowseOutput_Click"/>
              </Grid>
            </StackPanel>
          </Border>

          <!-- Token estimate -->
          <TextBlock Text="{Binding EstimatedTokenInfo}"
                     FontSize="12"
                     Foreground="#a78bfa"
                     Margin="4,4,0,0"
                     IsVisible="{Binding EstimatedTokenInfo, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

          <!-- Generate Button -->
          <Button Classes="primary" Margin="0,6"
                  Command="{Binding GenerateCommand}"
                  IsEnabled="{Binding CanGenerate}">
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <TextBlock Text="⚡" FontSize="16"/>
              <TextBlock Text="Generate Notes" FontSize="15"/>
            </StackPanel>
          </Button>

          <!-- Cancel button (visible during generation) -->
          <Button Classes="danger" Margin="0,0,0,6"
                  IsVisible="{Binding IsGenerating}"
                  Command="{Binding CancelGenerationCommand}"
                  HorizontalAlignment="Center"
                  Content="Cancel Generation"/>

          <!-- Progress -->
          <Border Classes="card" IsVisible="{Binding IsGenerating}">
            <StackPanel Spacing="6">
              <TextBlock Classes="sectionHeader" Text="⏳ Progress"/>
              <ProgressBar Value="{Binding ProgressPercent}" Maximum="100" Height="8"
                           Foreground="#7c3aed" Background="#1a1a2e"/>
              <TextBlock Text="{Binding ProgressMessage}" FontSize="12" Foreground="#999"/>
            </StackPanel>
          </Border>

          <!-- Live Preview -->
          <Border Classes="card" IsVisible="{Binding HasLivePreview}">
            <StackPanel Spacing="6">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Classes="sectionHeader" Text="📖 Live Preview"/>
                <TextBlock Grid.Column="1" FontSize="11" Foreground="#555"
                           VerticalAlignment="Center"
                           Text="{Binding LivePreview.Length, StringFormat='{}{0:N0} chars'}"/>
              </Grid>
              <Border Background="#0d0d1a" CornerRadius="6" Padding="10" BorderBrush="#1e2d4a" BorderThickness="1">
                <ScrollViewer MaxHeight="300" Name="LivePreviewScroller">
                  <TextBlock Text="{Binding LivePreview}"
                             FontFamily="Consolas, Courier New, monospace"
                             FontSize="12"
                             Foreground="#c0c0c0"
                             TextWrapping="Wrap"/>
                </ScrollViewer>
              </Border>
            </StackPanel>
          </Border>

          <!-- Status message -->
          <TextBlock Text="{Binding StatusMessage}"
                     FontSize="12"
                     TextWrapping="Wrap"
                     Margin="0,4"
                     Classes.error="{Binding IsStatusError}"
                     IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock.Styles>
              <Style Selector="TextBlock">
                <Setter Property="Foreground" Value="#4ade80"/>
              </Style>
              <Style Selector="TextBlock.error">
                <Setter Property="Foreground" Value="#f87171"/>
              </Style>
            </TextBlock.Styles>
          </TextBlock>

        </StackPanel>
      </ScrollViewer>

    </Grid>
  </Grid>
</Window>
