<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LectureSmith.App"
             xmlns:local="using:LectureSmith"
             RequestedThemeVariant="Dark">
             <!-- Enforce Dark theme variant regardless of OS system settings -->


    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>